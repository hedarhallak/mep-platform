# Environment variables — NEVER commit real secrets
.env
.env.local
.env.production
.env.*.local
.env.bak.*

# Secrets — defense in depth. The .secrets/ directory is the canonical
# location for credentials kept on the workstation (Cloudflare origin
# cert/key, Resend API key, password-manager exports, etc.). Plus a
# global *.key / *.pem catch in case someone drops a cert outside the
# folder. Added 2026-05-11 after a `git add -A` accidentally swept
# .secrets/ contents into a PR (PR #206, force-deleted). Always use
# explicit paths with `git add <file>` for credential-adjacent work,
# but these rules are the safety net.
.secrets/
*.key
*.pem
*.p12
*.pfx

# Deploy state — written by scripts/deploy.sh on prod (Section 54)
.last-deployed-sha

# Node modules
node_modules/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Uploads (user files)
uploads/*.pdf
uploads/*.jpg
uploads/*.png
uploads/*.jpeg

# Editor directories
.vscode/
.idea/

# Audit artifacts (Section 66 — local-only, regeneratable via knip / depcheck / vite-bundle-visualizer)
knip-backend-report.txt
knip-backend-report.json
knip-deps-only.txt
knip-postfix.txt
depcheck-backend.json
depcheck-frontend.json
mep-frontend/bundle-stats.json
mep-frontend/dist/

# Coverage reports (jest + vitest)
coverage/
mep-frontend/coverage/

# Local-only debug/coverage logs (Section 65 leftovers; regeneratable)
jest-cov-*.txt
jest-foremen-debug.txt

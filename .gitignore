# Environment variables — NEVER commit real secrets
.env
.env.local
.env.production
.env.*.local
.env.bak.*

# Deploy state — written by scripts/deploy.sh on prod (Section 54)
.last-deployed-sha

# Node modules
node_modules/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Uploads (user files)
uploads/*.pdf
uploads/*.jpg
uploads/*.png
uploads/*.jpeg

# Editor directories
.vscode/
.idea/

# Audit artifacts (Section 66 — local-only, regeneratable via knip / depcheck / vite-bundle-visualizer)
knip-backend-report.txt
knip-backend-report.json
knip-deps-only.txt
knip-postfix.txt
depcheck-backend.json
depcheck-frontend.json
mep-frontend/bundle-stats.json
mep-frontend/dist/

# Coverage reports (jest + vitest)
coverage/
mep-frontend/coverage/

# Local-only debug/coverage logs (Section 65 leftovers; regeneratable)
jest-cov-*.txt
jest-foremen-debug.txt

# Secrets folder (Phase 1 multi-tenant migration — Cloudflare Origin Cert + private key, etc.)
# NEVER commit anything inside .secrets/ — contains private keys
.secrets/
*.pem
*.key
!package-lock.json
!**/node_modules/**

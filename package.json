{
  "name": "mep-site-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "migrate": "node scripts/migrate.js",
    "audit:routes": "node scripts/check-routes.js",
    "audit:db": "node scripts/check-db.js",
    "audit": "node scripts/check-routes.js && node scripts/check-db.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:cov": "jest --coverage --coverageReporters=text-summary",
    "test:cov:check": "node -e \"if(!process.env.TEST_DATABASE_URL){console.error('TEST_DATABASE_URL must be set for full-coverage check (otherwise integration suites are skipped, giving misleading low numbers). Set it to your local test DB URL or run via CI.'); process.exit(1)} else { console.log('TEST_DATABASE_URL set, running full coverage...') }\" && npm run test:cov",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.696.0",
    "@sendgrid/mail": "^8.1.5",
    "@sentry/node": "^10.52.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.13.3",
    "puppeteer": "^24.43.1",
    "resend": "^4.8.0",
    "sharp": "^0.34.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,yml,yaml,html,css}": "prettier --write"
  }
}

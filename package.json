    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.13.3",
    "puppeteer": "^24.39.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",

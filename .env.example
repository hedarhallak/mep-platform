# =============================================================================
# Constrai / MEP Platform — Backend Environment Variables (template)
# =============================================================================
# Copy this file to `.env` (in the same directory as index.js) and fill in
# real values. NEVER commit a populated .env to git.
#
# On the production server (/var/www/mep), the populated .env should already
# exist. This file documents what variables exist and what they're for.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# Primary connection string. If set, DATABASE_URL takes precedence over PG*.
DATABASE_URL=postgresql://mepuser:CHANGE_ME@localhost:5432/mepdb

# Fallback components (used only if DATABASE_URL is not set).
# PGHOST=localhost
# PGPORT=5432
# PGUSER=mepuser
# PGPASSWORD=CHANGE_ME
# PGDATABASE=mepdb

# Phase 4 Stage 2 / Stage 3 (Section 89 + Section 90 / Piece 90-G):
# SUPER pool, connects as mepuser_super (BYPASSRLS). Used by:
#
#   1. middleware/tenant_db.js — SUPER_ADMIN cross-tenant routes need to
#      see every tenant's data, not just the current one.
#
#   2. routes/auth.js — pre-tenant SELECTs against app_users / companies
#      (login, refresh, whoami, change-pin). Under Stage 3 strict RLS
#      (migration 013) these queries return 0 rows from the regular pool
#      because no `app.company_id` GUC is set yet. The superPool bypasses
#      RLS so login lookups succeed. See DECISIONS.md Section 90 / Piece
#      90-F for the May 11, 2026 outage that motivated this addition,
#      and Pitfall #28 for the underlying convention.
#
# REQUIRED in production once migration 013 (Stage 3 strict RLS) is
# applied — without it, every login attempt fails with 400/401. Safely
# unset on local dev that hasn't applied 013 (Stage 1 permissive RLS
# allows the GUC-unset state, so the regular pool fallback works).
DATABASE_URL_SUPER=postgresql://mepuser_super:CHANGE_ME@localhost:5432/mepdb

# Password for the mepuser_super role. Used ONLY when running the one-time
# DBA setup script:
#   sudo -u postgres psql -d mepdb \
#     -v MEPUSER_SUPER_PASSWORD="$MEPUSER_SUPER_PASSWORD" \
#     -f scripts/postgres/setup_rls_roles.sql
# The same password is also embedded in DATABASE_URL_SUPER above so the
# backend can connect. Store the actual value in the password manager;
# never commit a real value to git.
MEPUSER_SUPER_PASSWORD=CHANGE_ME


# -----------------------------------------------------------------------------
# Auth / JWT (REQUIRED)
# -----------------------------------------------------------------------------
# Signing key for access + refresh tokens. MUST be a long random string.
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING_64_CHARS_MIN

# ADMIN_API_KEY removed in Section 91 audit (May 11, 2026) — never read
# by any code path. Was documented as an "optional shared secret" but
# the backend always falls back to role-based auth. AUTH_SECRET (which
# was set in some older prod .env files but never documented here) is
# in the same boat: orphan env var, no readers. Both deleted from prod
# .env as part of the post-leak cleanup. If a future feature needs a
# shared-secret pattern, name it explicitly and document it here from
# day one.


# -----------------------------------------------------------------------------
# Email — provider-agnostic via lib/email.js#getMailClient (REQUIRED for
# invite / activation / PO / dispatch / weekly report / CCQ reminder emails)
# -----------------------------------------------------------------------------
# Provider selector. 'resend' is the production default since the Section
# 92.5 cutover (May 11, 2026). 'sendgrid' is kept as an emergency fallback
# inside lib/email.js but route-level callers no longer reference
# SENDGRID_API_KEY directly (Section 98, May 13, 2026).
EMAIL_PROVIDER=resend

# Resend API key (REQUIRED when EMAIL_PROVIDER=resend). Get it from:
#   https://resend.com/api-keys
# Local copy stored in OneDrive `Constrai Keys` folder.
RESEND_API_KEY=re_CHANGE_ME

# Sender shown in From: header. Domain must be verified in Resend (or in
# SendGrid for the legacy fallback). The var name retains the SENDGRID_
# prefix for backward compat with deployed .env files; it's just the From
# address and works with either provider.
SENDGRID_FROM_EMAIL=noreply@constrai.ca

# SendGrid API key — DEPRECATED. Only needed if EMAIL_PROVIDER=sendgrid
# (emergency rollback). New deploys do not require this. Removed from prod
# in Section 98 (May 13, 2026).
# SENDGRID_API_KEY=SG.CHANGE_ME


# -----------------------------------------------------------------------------
# Maps — Mapbox (used for project geocoding + workforce planner)
# -----------------------------------------------------------------------------
# Public token (pk.*). Required for /api/geocode/suggest and BI distance calcs.
MAPBOX_ACCESS_TOKEN=pk.CHANGE_ME


# -----------------------------------------------------------------------------
# App URLs (REQUIRED — used in emails, redirect links)
# -----------------------------------------------------------------------------
# Backend base URL. NO trailing slash. Used for auth callbacks + email links
# back to the API.
APP_BASE_URL=https://app.constrai.ca

# Frontend (web app) URL. Used in dispatch emails for "Open in Constrai" links.
APP_URL=https://app.constrai.ca


# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Server port (default 3000).
PORT=3000

# Runtime environment. Affects logging verbosity + some middleware behavior.
# Values: development | production | test
NODE_ENV=production

# Display name (shown in email templates). Default: "MEP Platform".
APP_NAME=Constrai

# How long employee/user invite codes remain valid (hours). Default: 48.
USER_INVITE_EXPIRES_HOURS=48


# -----------------------------------------------------------------------------
# Observability — Sentry (Phase 64, May 2026)
# -----------------------------------------------------------------------------
# Sentry DSN — captures uncaught exceptions + slow requests. Get it from:
#   https://constrai.sentry.io/settings/projects/constrai-backend/keys/
# When unset, Sentry stays disabled (no events sent) — safe for local dev.
# When set in prod, instrument.js initializes Sentry before any other module.
SENTRY_DSN=

# Optional: short SHA of the release this deploy belongs to. Set by the
# deploy script (e.g. `RELEASE_SHA=$(git rev-parse --short HEAD)`). Sentry
# tags every event with this value so we can correlate errors to deploys.
RELEASE_SHA=


# -----------------------------------------------------------------------------
# Health probe paths (Phase 66, May 2026 — used by /api/health/deep)
# -----------------------------------------------------------------------------
# Both are optional. Defaults match the production Droplet layout. Override
# only for non-standard deployments or local dev where the paths differ.

# Filesystem path used by the disk-space readiness check. Default:
# /var/lib/postgresql (the postgres data directory on Ubuntu). The check
# returns "skipped" when the path doesn't exist (e.g. local dev), so it's
# safe to leave unset off prod.
DISK_CHECK_PATH=

# Backup script log file inspected by the backup-age readiness check.
# Default: /var/log/mep-backup.log (where scripts/backup/backup_db.sh
# appends one line per cron run). The check returns "skipped" when the
# log doesn't exist or has no completion marker yet.
BACKUP_LOG_PATH=


# -----------------------------------------------------------------------------
# DigitalOcean Spaces — tenant assets bucket (Phase 6-D-3, Section 112)
# -----------------------------------------------------------------------------
# S3-compatible object storage for tenant-uploaded assets (today: company
# logos). DELIBERATELY a SEPARATE bucket from the backup bucket so the
# credential blast radius is small and ACLs/CORS can differ (logos are
# public-read; backups are private).
#
# Create the bucket via the DO dashboard:
#   Cloud → Spaces → Create a Space → Name: constrai-tenant-assets
#   → Region: TOR1 (or whichever you use)
#   → CORS: allow GET from https://*.constrai.ca
#   → File listing: Restricted (public reads work per-object via ACL)
#
# Then create access keys at:
#   Cloud → API → Spaces Keys → Generate New Key (one per bucket recommended)
#
# When any of the 6 vars are missing/empty, the upload route returns
# 500 SPACES_NOT_CONFIGURED — Sentry will fire if it's used in that state.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=constrai-tenant-assets
DO_SPACES_REGION=tor1
DO_SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
# Public URL prefix where uploaded objects can be fetched. With Spaces
# CDN enabled, use the CDN hostname for cache acceleration:
#   https://constrai-tenant-assets.tor1.cdn.digitaloceanspaces.com
# Without CDN, use the direct Spaces hostname:
#   https://constrai-tenant-assets.tor1.digitaloceanspaces.com
DO_SPACES_PUBLIC_URL_BASE=https://constrai-tenant-assets.tor1.cdn.digitaloceanspaces.com

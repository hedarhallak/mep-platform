# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/erp

# JWT — use a long random string (64+ chars), e.g.: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING_HERE

# Admin API Key
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

# SendGrid Email
SENDGRID_API_KEY=SG.YOUR_KEY_HERE
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# App URL (no trailing slash)
APP_BASE_URL=http://localhost:3000

# Mapbox Geocoding
MAPBOX_ACCESS_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE

# Invite expiry in hours (default: 48)
USER_INVITE_EXPIRES_HOURS=48

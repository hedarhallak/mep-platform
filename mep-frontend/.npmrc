# Tech debt — Section 19 (April 27, 2026):
# vite-plugin-pwa@0.21.x peer-deps require vite 3-6, but the project runs
# on vite 7. The lockfile was originally generated under legacy peer-deps
# behavior; `npm ci` on modern npm becomes strict and refuses to install.
#
# This setting matches the lockfile's existing resolution. Remove it once
# vite-plugin-pwa is upgraded to v1.x (which natively supports vite 7).
legacy-peer-deps=true

# mep-frontend environment variables (Vite — build-time only).
#
# Copy this file to `.env` (gitignored) for local development, OR set
# these as build-time env vars on the deploy host (CI / Vercel / etc.).
#
# Variables prefixed with VITE_ are inlined into the client bundle at
# build time and ARE visible to anyone inspecting the JS — never put
# server secrets here.

# Mapbox public token used by the onboarding page geocoder.
# Public-scoped (`pk.*`) so safe to ship in the bundle, but rotation
# requires a rebuild + redeploy. Get from https://account.mapbox.com/
# under "Tokens".
VITE_MAPBOX_TOKEN=pk.replace_me_with_your_mapbox_public_token

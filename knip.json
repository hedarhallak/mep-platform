{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "index.js",
        "instrument.js",
        "app.js",
        "scripts/*.js",
        "jobs/*.js",
        "seed.js",
        "tests/**/*.test.js"
      ],
      "project": [
        "index.js",
        "instrument.js",
        "app.js",
        "db.js",
        "seed.js",
        "routes/**/*.js",
        "lib/**/*.js",
        "middleware/**/*.js",
        "services/**/*.js",
        "scripts/**/*.js",
        "jobs/**/*.js",
        "tests/**/*.js"
      ]
    }
  },
  "ignoreWorkspaces": ["mep-frontend", "mep-mobile", "uploads", "constrai-landing"],
  "ignore": [
    "node_modules/**",
    "mep-frontend/**",
    "mep-mobile/**",
    "public/**",
    "dist/**",
    "build/**",
    "uploads/**",
    "data/**",
    "coverage/**",
    "constrai-landing/**",
    "db/**",
    "docs/**",
    "tools/**",
    ".expo/**",
    "**/*.md",
    "**/*.txt",
    "**/*.json"
  ]
}
